NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://127.0.0.1:5173
PYTHON_BIN=/opt/anaconda3/bin/python3

DATABASE_PATH=apps/api/data/melodify.sqlite3
CACHE_DIR=apps/api/.cache/audio
TEMP_CACHE_DIR=apps/api/.cache/temp
ARTWORK_CACHE_DIR=apps/api/.cache/artwork
SHARED_CACHE_DIR=
REFRESH_ENABLED=true
REFRESH_MANIFEST_URL=https://raw.githubusercontent.com/LokeshVK07/Sruthi_2.o/main/apps/api/data/library-manifest.json
REFRESH_INTERVAL_SECONDS=21600
REFRESH_TIMEOUT_SECONDS=60

MASSTAMILAN_BASE_URL=https://www.masstamilan.dev
MASSTAMILAN_LIST_PATH=/tamil-songs
MASSTAMILAN_MAX_PAGES=481

MAX_CACHE_SIZE_MB=4096
MIN_CACHE_FILE_BYTES=65536
STREAM_PREFETCH_LIMIT=8
WARMUP_BATCH_SIZE=24
