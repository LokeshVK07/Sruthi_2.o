{
  "name": "@melodify/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:init": "tsx src/scripts/init-db.ts",
    "seed": "tsx src/scripts/seed-demo.ts",
    "scrape": "tsx src/scripts/run-scrape.ts",
    "scrape:incremental": "tsx src/scripts/run-scrape.ts --incremental",
    "smoke": "tsx src/scripts/smoke-test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.913.0",
    "@aws-sdk/lib-storage": "^3.913.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.4.1",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "mime-types": "^3.0.1",
    "nanoid": "^5.1.6",
    "playwright": "^1.56.1",
    "undici": "^7.16.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
